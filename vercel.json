{
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/joventy run build",
  "outputDirectory": "artifacts/joventy/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "BASE_PATH": "/"
  }
}
